{
  "entities": {
    "ProductionLine": {
      "title": "ProductionLine",
      "description": "Production line grouping machines",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Machine": {
      "title": "Machine",
      "description": "Industrial machine configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "productionLineId": { "type": "string" },
        "theoreticalProductionPerHour": { "type": "number" },
        "hourlyGoal": { "type": "number" }
      },
      "required": ["id", "name", "productionLineId", "theoreticalProductionPerHour"]
    },
    "ProductionRecord": {
      "title": "ProductionRecord",
      "description": "Record of production for a machine",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "quantity": { "type": "number" },
        "scrapQuantity": { "type": "number" }
      },
      "required": ["id", "machineId", "date", "startTime", "endTime"]
    },
    "DowntimeRecord": {
      "title": "DowntimeRecord",
      "description": "Record of downtime for a machine",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "type": { "type": "string" },
        "observation": { "type": "string" }
      },
      "required": ["id", "machineId", "date", "startTime"]
    },
    "DowntimeReason": {
      "title": "DowntimeReason",
      "description": "Configurable downtime reason with color",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "color"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User permissions and role",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "canEdit": { "type": "boolean" },
        "canDelete": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["email", "canEdit", "canDelete", "role"]
    }
  },
  "firestore": {
    "/productionLines/{lineId}": {
      "schema": "ProductionLine",
      "description": "Collection of production lines"
    },
    "/machines/{machineId}": {
      "schema": "Machine",
      "description": "Collection of industrial machines"
    },
    "/production/{productionId}": {
      "schema": "ProductionRecord",
      "description": "Collection of production records"
    },
    "/downtime/{downtimeId}": {
      "schema": "DowntimeRecord",
      "description": "Collection of downtime records"
    },
    "/downtimeReasons/{reasonId}": {
      "schema": "DowntimeReason",
      "description": "Collection of configurable downtime reasons"
    },
    "/userProfiles/{profileId}": {
      "schema": "UserProfile",
      "description": "Collection of user permissions"
    }
  }
}
